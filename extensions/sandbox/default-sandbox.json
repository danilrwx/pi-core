{
  "enabled": true,
  "mode": "interactive",
  "network": {
    "allowedDomains": [
      "*"
    ],
    "deniedDomains": []
  },
  "enableWeakerNetworkIsolation": true,
  "filesystem": {
    "allowRead": [
      "/**"
    ],
    "allowWrite": [
      ".",
      "/private/tmp",
      "/private/tmp",
      "/tmp",
      "/tmp",
      "/var/tmp",
      "/var/tmp",
      "~/.cache",
      "~/.config",
      "~/.local",
      "~/.npm",
      "~/.pi",
      "~/.pnpm-store",
      "~/.yarn",
      "~/Library/Caches"
    ],
    "denyRead": [],
    "denyWrite": [
      "~/.ssh",
      "~/.gnupg",
      "~/.aws",
      "~/.kube",
      "~/.kubeconfig",
      "~/Library/Keychains"
    ]
  }
}
